{
  "name": "zakamurai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "npx playwright test",
    "setup:almostnode": "mkdir -p public/lib/almostnode public/assets && cp -r node_modules/almostnode/dist/* public/lib/almostnode/ && cp node_modules/almostnode/dist/assets/* public/assets/",
    "setup:wasm": "mkdir -p public/wasm && cp node_modules/onnxruntime-web/dist/* public/wasm/",
    "postinstall": "\"$npm_execpath\" run setup:almostnode && \"$npm_execpath\" run setup:wasm",
    "predev": "\"$npm_execpath\" run setup:almostnode && \"$npm_execpath\" run setup:wasm",
    "prebuild": "\"$npm_execpath\" run setup:almostnode && \"$npm_execpath\" run setup:wasm",
    "verify": "biome check . && vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@mlc-ai/web-llm": "^0.2.83",
    "@testing-library/dom": "^10.4.1",
    "almostnode": "latest",
    "apache-arrow": "^18.1.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "wasm-loader": "^1.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@next/bundle-analyzer": "latest",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^26.0.0",
    "vitest": "^3.0.4",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "fast-check": "^3.0.0",
    "promptfoo": "latest",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "latest",
    "@playwright/test": "latest"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": ["biome check --write", "vitest related --run", "npx playwright test"],
    "src/**/*.module.css": ["stylelint --fix"]
  }
}
